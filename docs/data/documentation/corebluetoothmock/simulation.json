{"hierarchy":{"paths":[["doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock"]]},"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CoreBluetoothMock","type":"text"}],"type":"strong"},{"type":"text","text":" framework allows to simulate various events that can happen in"},{"type":"text","text":" "},{"type":"text","text":"real life scenario. Those include turning OFF Bluetooth, resetting the device, sending"},{"type":"text","text":" "},{"type":"text","text":"notifications, moving devices out of range, etc."}]},{"level":3,"anchor":"","type":"heading","text":""},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateConnection()","isActive":true,"type":"reference"},{"type":"text","text":" - simulates a situation when another app on the iDevice"},{"type":"text","text":" "},{"type":"text","text":"connected to this peripheral. The device will stop advertising (unless "},{"code":"advertisingWhenConnected","type":"codeVoice"},{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"flag was set) and will be available using"},{"type":"text","text":" "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManager\/retrieveConnectedPeripherals(withServices:)","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateDisconnection(withError:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates a connection error."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateReset()","isActive":true,"type":"reference"},{"type":"text","text":" - simulates device hard reset. The central will notify"},{"type":"text","text":" "},{"type":"text","text":"delegates 4 seconds (supervision timeout) after the device has been reset."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateProximityChange(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates moving the peripheral close or away"},{"type":"text","text":" "},{"type":"text","text":"from the device."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateValueUpdate(_:for:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates sending a notification or indication"},{"type":"text","text":" "},{"type":"text","text":"from the device. All subscribed clients will be notified a connection interval later."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateAdvertisementChange(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates change of the advertisemet data"},{"type":"text","text":" "},{"type":"text","text":"of the peripheral. The peripheral will stop advertising with previous data and start with the new set."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateCaching()","isActive":true,"type":"reference"},{"type":"text","text":" - simulates caching the device by the iDevice."},{"type":"text","text":" "},{"type":"text","text":"Caching pairs the device’s MAC with a random identifier (UUID). A device is also cached whenever"},{"type":"text","text":" "},{"type":"text","text":"it is scanned. Caching makes the device available to be retrieved using"},{"type":"text","text":" "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManager\/retrievePeripherals(withIdentifiers:)","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateMacChange(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates the device changing its MAC address."},{"type":"text","text":" "},{"type":"text","text":"The iDevice will not contain any cached information about the device, as with the new MAC it is"},{"type":"text","text":" "},{"type":"text","text":"considered to be a new device."}]},{"level":3,"anchor":"Bluetooth-State-Changes","type":"heading","text":"Bluetooth State Changes"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulatePeripherals(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - creates a simulation with given list of mock"},{"type":"text","text":" "},{"type":"text","text":"peripheral. This method should be called when the manager is powered off, or before any"},{"type":"text","text":" "},{"type":"text","text":"central manager was initialized."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulateInitialState(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - this method should be called before any central"},{"type":"text","text":" "},{"type":"text","text":"manager instance was created. It defines the initial state of the mock central manager."},{"type":"text","text":" "},{"type":"text","text":"By default, the manager is powered off."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulatePowerOn()","isActive":true,"type":"reference"},{"type":"text","text":" - turns on the mock central manager."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulatePowerOff()","isActive":true,"type":"reference"},{"type":"text","text":" - turns off the mock central manager."},{"type":"text","text":" "},{"type":"text","text":"All scans and connections will be terminated."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/tearDownSimulation()","isActive":true,"type":"reference"},{"type":"text","text":" - sets the state of all currently existing central"},{"type":"text","text":" "},{"type":"text","text":"managers to "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMManagerState\/unknown","isActive":true,"type":"reference"},{"type":"text","text":" and clears the list of managers and peripherals bringing"},{"type":"text","text":" "},{"type":"text","text":"the mock manager to initial state."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulateStateRestoration","isActive":true,"type":"reference"},{"type":"text","text":" - this closure will be used when you initiate a"},{"type":"text","text":" "},{"type":"text","text":"central manager with "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerOptionRestoreIdentifierKey","isActive":true,"type":"reference"},{"type":"text","text":" option. The map returned will be"},{"type":"text","text":" "},{"type":"text","text":"passed to "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerDelegate\/centralManager(_:willRestoreState:)","isActive":true,"type":"reference"},{"type":"text","text":" callback in"},{"type":"text","text":" "},{"type":"text","text":"central manager’s delegate."}]},{"type":"paragraph","inlineContent":[{"code":"CBMCentralManagerMock\/simulateFeaturesSupport","type":"codeVoice"},{"type":"text","text":" - this closure will be used to emulate Bluetooth"},{"type":"text","text":" "},{"type":"text","text":"features supported by the manager. It is available on iOS 13+, tvOS 13+ or watchOS 6+."}]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulateAuthorization(_:)","isActive":true,"type":"reference"},{"type":"text","text":" - simulates the current authorization state"},{"type":"text","text":" "},{"type":"text","text":"of a Core Bluetooth manager. When any value other than "},{"code":".allowedAlways","type":"codeVoice"},{"type":"text","text":" is returned, the"},{"type":"text","text":" "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManager","isActive":true,"type":"reference"},{"type":"text","text":" will change state to "},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMManagerState\/unauthorized","isActive":true,"type":"reference"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/Simulation","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Set of methods for simulating various Bluetooth LE events."}],"metadata":{"title":"Simulation","modules":[{"name":"CoreBluetoothMock"}],"roleHeading":"Article","role":"article"},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/corebluetoothmock\/simulation"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://CoreBluetoothMock/documentation/CoreBluetoothMock/CBMCentralManagerMock/simulatePowerOn()":{"title":"simulatePowerOn()","kind":"symbol","identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMCentralManagerMock\/simulatePowerOn()","url":"\/documentation\/corebluetoothmock\/cbmcentralmanagermock\/simulatepoweron()","role":"symbol","fragments":[{"kind":"keywor