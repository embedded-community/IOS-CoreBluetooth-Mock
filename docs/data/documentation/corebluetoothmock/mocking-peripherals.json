,{"text":" ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateAdvertisementChange(_:)","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Connection","anchor":"Connection"},{"inlineContent":[{"text":"The","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/Builder\/connectable(name:services:delegate:connectionInterval:supervisionTimeout:mtu:)","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/Builder\/connected(name:services:delegate:connectionInterval:supervisionTimeout:mtu:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"methods allows to specify a ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpecDelegate","isActive":true,"type":"reference"},{"text":". This object defines the behavior of the","type":"text"},{"text":" ","type":"text"},{"text":"mock peripheral, how will it respond to Bluetooth LE requests, a hard reset, etc. The implementation","type":"text"},{"text":" ","type":"text"},{"text":"should mimic the behavior of the real device as much as possible to make the tests reliable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To test how the app handles connection interruptions, the mock connection can be terminated using","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateReset()","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/CoreBluetoothMock\/documentation\/CoreBluetoothMock\/CBMPeripheralSpec\/simulateDisconnection(withError:)","isActive":true,"type":"reference"},{"tex